{
  "manifest_version": 3,
  "name": "Verifai Lens",
  "version": "1.0",
  "description": "AI-powered content verification — detect deepfakes, misinformation, and suspicious URLs as you browse.",

  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "http://localhost:8000/*",
    "https://api.verifai.app/*",
    "*://*.facebook.com/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["platforms/facebook.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Verifai Lens",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [{
    "resources": ["report/report.html", "report/report.js", "icons/*"],
    "matches": ["<all_urls>"]
  }]
}
