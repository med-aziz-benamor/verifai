# ==============================
# Verifai Backend — Environment Variables
# Copy this file to .env and fill in your API keys.
# Never commit .env to git.
# ==============================

# Sightengine — image & video analysis
# Get your key at: https://sightengine.com  (free tier: 500 ops/month)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# HuggingFace — AI text detection (free, no credit card)
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Anthropic Claude — context reasoning
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# URLScan.io — URL sandbox analysis
# Get your key at: https://urlscan.io/user/signup  (free tier available)
URLSCAN_API_KEY=

# Google Safe Browsing — threat intelligence
# Get your key at: https://console.cloud.google.com → Enable Safe Browsing API
GOOGLE_SAFE_BROWSING_KEY=
