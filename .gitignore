# ==============================
# Verifai — .gitignore
# ==============================

# ---- Environment Variables ----
.env
.env.local
.env.*.local
!.env.example

# ---- Node / Next.js ----
node_modules/
.next/
out/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.log

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
# Allow extension icons (Icon? pattern above would match the icons/ dir on macOS)
!extension/icons/
!extension/icons/*.png

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace

# ---- Misc ----
*.pem
*.key
uploads/
tmp/
